<% if notice.present? %>
  <div class="fixed top-20 right-4 z-50 max-w-sm flex items-center justify-between bg-green-50 border border-green-300 shadow-lg rounded-xl px-4 py-3 text-sm text-green-800"
       data-controller="flash" data-action="click->flash#dismiss">
    <span><%= notice %></span>
    <button class="text-green-400 hover:text-green-600 ml-4">&times;</button>
  </div>
<% end %>

<% if alert.present? %>
  <div class="fixed top-20 right-4 z-50 max-w-sm flex items-center justify-between bg-red-50 border border-red-300 shadow-lg rounded-xl px-4 py-3 text-sm text-red-800"
       data-controller="flash" data-action="click->flash#dismiss">
    <span><%= alert %></span>
    <button class="text-red-400 hover:text-red-600 ml-4">&times;</button>
  </div>
<% end %>
