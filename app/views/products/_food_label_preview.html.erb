<div class="bg-white rounded-xl shadow-sm p-6" data-controller="food-label">
  <div class="flex justify-between items-center mb-3">
    <p class="text-sm font-medium text-gray-700">食品表示ラベル</p>
    <button type="button"
      data-action="food-label#copy"
      data-food-label-target="copyButton"
      class="text-gray-400 hover:text-orange-500 cursor-pointer"
      title="テキストをコピー">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
      </svg>
    </button>
  </div>

  <% materials_list = product.product_materials.reject(&:marked_for_destruction?).select { |pm| pm.material.present? } %>
  <% ingredients = materials_list.select { |pm| !pm.material.additive? }.sort_by { |pm| -(pm.quantity || 0) } %>
  <% additives = materials_list.select { |pm| pm.material.additive? }.sort_by { |pm| -(pm.quantity || 0) } %>
  <% all_allergens = product.allergens.map(&:label_name).uniq %>

  <div data-food-label-target="preview" class="mx-auto space-y-3" style="max-width: 400px;">
    <div class="border border-black p-3 text-xs leading-relaxed" style="font-family: 'Hiragino Kaku Gothic ProN', 'Yu Gothic', sans-serif;">
      <dl>
        <div class="flex gap-1">
          <dt class="shrink-0 font-bold">名称</dt>
          <dd><%= product.category %></dd>
        </div>
        <div class="flex gap-1 mt-1">
          <dt class="shrink-0 font-bold">原材料名</dt>
          <dd>
            <%
              ingredient_names = ingredients.map { |pm| pm.material.display_name.presence || pm.material.name }
              additive_names = additives.map { |pm| pm.material.display_name.presence || pm.material.name }
            %>
            <% if ingredient_names.any? || additive_names.any? %>
              <%= ingredient_names.join("、") %><% if additive_names.any? %>／<%= additive_names.join("、") %><% end %><% if all_allergens.any? %>（一部に<%= all_allergens.join("・") %>を含む）<% end %>
            <% else %>
              <span class="text-gray-400">-</span>
            <% end %>
          </dd>
        </div>
        <div class="flex gap-1 mt-1">
          <dt class="shrink-0 font-bold">内容量</dt>
          <dd><span class="text-gray-400">（要入力）</span></dd>
        </div>
        <div class="flex gap-1 mt-1">
          <dt class="shrink-0 font-bold">消費期限</dt>
          <dd><span class="text-gray-400">（要入力）</span></dd>
        </div>
        <div class="flex gap-1 mt-1">
          <dt class="shrink-0 font-bold">保存方法</dt>
          <dd><span class="text-gray-400">（要入力）</span></dd>
        </div>
        <div class="flex gap-1 mt-1">
          <dt class="shrink-0 font-bold">製造者</dt>
          <dd><span class="text-gray-400">（要入力）</span></dd>
        </div>
      </dl>
    </div>

    <div class="border border-black p-3 text-xs leading-relaxed" style="font-family: 'Hiragino Kaku Gothic ProN', 'Yu Gothic', sans-serif;">
      <p class="font-bold border-b border-black pb-1 mb-1">栄養成分表示（1個あたり）</p>
      <% if product.has_nutrition_data? %>
        <table class="w-full">
          <tbody>
            <tr>
              <td class="py-0.5">エネルギー</td>
              <td class="py-0.5 text-right"><%= product.total_energy.round(1) %> kcal</td>
            </tr>
            <tr>
              <td class="py-0.5">たんぱく質</td>
              <td class="py-0.5 text-right"><%= product.total_protein.round(1) %> g</td>
            </tr>
            <tr>
              <td class="py-0.5">脂質</td>
              <td class="py-0.5 text-right"><%= product.total_fat.round(1) %> g</td>
            </tr>
            <tr>
              <td class="py-0.5">炭水化物</td>
              <td class="py-0.5 text-right"><%= product.total_carbohydrate.round(1) %> g</td>
            </tr>
            <tr>
              <td class="py-0.5">食塩相当量</td>
              <td class="py-0.5 text-right"><%= product.total_salt.round(1) %> g</td>
            </tr>
          </tbody>
        </table>
      <% else %>
        <p class="text-gray-400">-</p>
      <% end %>
    </div>
  </div>
</div>
