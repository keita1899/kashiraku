<div class="bg-white rounded-xl shadow-sm p-6 mb-6">
  <p class="text-sm font-medium text-gray-700 mb-3">アレルゲン</p>

  <% required = product.required_allergens %>
  <% recommended = product.recommended_allergens %>

  <div class="space-y-3">
    <div data-allergen-display-target="requiredSection" class="<%= 'hidden' unless required.any? %>">
      <p class="text-xs text-gray-500 mb-1">特定原材料</p>
      <div data-allergen-display-target="requiredBadges" class="flex flex-wrap gap-1">
        <% required.each do |allergen| %>
          <span class="text-xs px-1.5 py-0.5 rounded bg-red-50 text-red-600"><%= allergen.name %></span>
        <% end %>
      </div>
    </div>

    <div data-allergen-display-target="recommendedSection" class="<%= 'hidden' unless recommended.any? %>">
      <p class="text-xs text-gray-500 mb-1">推奨品目</p>
      <div data-allergen-display-target="recommendedBadges" class="flex flex-wrap gap-1">
        <% recommended.each do |allergen| %>
          <span class="text-xs px-1.5 py-0.5 rounded bg-yellow-50 text-yellow-700"><%= allergen.name %></span>
        <% end %>
      </div>
    </div>

    <p data-allergen-display-target="emptyMessage" class="text-sm text-gray-400 <%= 'hidden' if required.any? || recommended.any? %>">該当するアレルゲンはありません</p>
  </div>
</div>
