<div class="max-w-5xl mx-auto">
  <%= link_to "← 商品一覧に戻る", products_path, class: "text-sm text-gray-500 hover:text-gray-700 mb-4 inline-block" %>
  <h1 class="text-2xl font-bold text-gray-900 mb-6">商品を登録</h1>

  <%= form_with(model: @product, class: "space-y-6", data: { controller: "cost-calculator allergen-display nutrition-calculator" }) do |f| %>
    <div class="flex flex-col lg:flex-row gap-8">
      <div class="lg:w-3/5 space-y-6">
        <%= render "form_fields", f: f, product: @product, materials: @materials %>
      </div>

      <div class="lg:w-2/5">
        <div class="lg:sticky lg:top-20 space-y-6">
          <%= render "cost_summary", product: @product %>
          <%= render "nutrition_summary", product: @product %>
          <%= render "allergen_summary", product: @product %>
        </div>
      </div>
    </div>

    <div class="flex justify-center gap-4">
      <%= link_to "キャンセル", products_path, class: "bg-gray-200 text-gray-700 px-12 py-3 rounded-lg hover:bg-gray-300 text-sm font-medium text-center" %>
      <%= f.submit class: "bg-orange-500 text-white px-12 py-3 rounded-lg hover:bg-orange-600 text-sm font-medium cursor-pointer" %>
    </div>
  <% end %>
</div>
