<div class="bg-white rounded-xl shadow-sm p-6">
  <div class="flex justify-between items-center mb-3">
    <p class="text-sm font-medium text-gray-700">栄養成分表示</p>
    <button type="button"
      data-nutrition-calculator-target="toggleButton"
      data-action="nutrition-calculator#toggleDisplay"
      class="text-orange-500 hover:text-orange-700 text-sm font-medium cursor-pointer">
      100gあたりに切替
    </button>
  </div>

  <div data-nutrition-calculator-target="summary" class="<%= 'hidden' unless product.has_nutrition_data? %>">
    <div data-nutrition-calculator-target="perItemSection">
      <p class="text-xs text-gray-500 mb-2">1個あたり</p>
      <dl class="space-y-1">
        <div class="flex justify-between">
          <dt class="text-sm text-gray-700">エネルギー</dt>
          <dd class="text-sm font-bold text-gray-900" data-nutrition-calculator-target="energy"><%= product.total_energy.round(1) %> kcal</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-700">たんぱく質</dt>
          <dd class="text-sm font-bold text-gray-900" data-nutrition-calculator-target="protein"><%= product.total_protein.round(1) %> g</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-700">脂質</dt>
          <dd class="text-sm font-bold text-gray-900" data-nutrition-calculator-target="fat"><%= product.total_fat.round(1) %> g</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-700">炭水化物</dt>
          <dd class="text-sm font-bold text-gray-900" data-nutrition-calculator-target="carbohydrate"><%= product.total_carbohydrate.round(1) %> g</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-700">食塩相当量</dt>
          <dd class="text-sm font-bold text-gray-900" data-nutrition-calculator-target="salt"><%= product.total_salt.round(1) %> g</dd>
        </div>
      </dl>
    </div>

    <div data-nutrition-calculator-target="per100gSection" class="hidden">
      <p class="text-xs text-gray-500 mb-2">100gあたり</p>
      <dl class="space-y-1">
        <div class="flex justify-between">
          <dt class="text-sm text-gray-700">エネルギー</dt>
          <dd class="text-sm font-bold text-gray-900" data-nutrition-calculator-target="energyPer100g"><%= product.nutrition_per_100g(:energy) %> kcal</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-700">たんぱく質</dt>
          <dd class="text-sm font-bold text-gray-900" data-nutrition-calculator-target="proteinPer100g"><%= product.nutrition_per_100g(:protein) %> g</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-700">脂質</dt>
          <dd class="text-sm font-bold text-gray-900" data-nutrition-calculator-target="fatPer100g"><%= product.nutrition_per_100g(:fat) %> g</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-700">炭水化物</dt>
          <dd class="text-sm font-bold text-gray-900" data-nutrition-calculator-target="carbohydratePer100g"><%= product.nutrition_per_100g(:carbohydrate) %> g</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-700">食塩相当量</dt>
          <dd class="text-sm font-bold text-gray-900" data-nutrition-calculator-target="saltPer100g"><%= product.nutrition_per_100g(:salt) %> g</dd>
        </div>
      </dl>
    </div>
  </div>

  <p data-nutrition-calculator-target="emptyMessage"
     class="text-sm text-gray-400 <%= 'hidden' if product.has_nutrition_data? %>">
    栄養成分データがありません
  </p>
</div>
