<%= form_with(model: material, class: "space-y-6", data: { controller: "unit-price" }) do |f| %>
  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "w-full border #{error_border(f.object, :name)} rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500" %>
    <%= render "shared/field_errors", object: material, field: :name %>
  </div>

  <div>
    <%= f.label :display_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :display_name, class: "w-full border #{error_border(f.object, :display_name)} rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500" %>
    <p class="text-xs text-gray-500 mt-1">食品表示ラベルに表示する名前（空欄の場合は原材料名を使用）</p>
    <%= render "shared/field_errors", object: material, field: :display_name %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :purchase_price, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :purchase_price, step: 0.01, min: 0,
          data: { unit_price_target: "price", action: "input->unit-price#calculate" },
          class: "w-full border #{error_border(f.object, :purchase_price)} rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500" %>
      <%= render "shared/field_errors", object: material, field: :purchase_price %>
    </div>

    <div>
      <%= f.label :purchase_quantity, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :purchase_quantity, step: 0.01, min: 0,
          data: { unit_price_target: "quantity", action: "input->unit-price#calculate" },
          class: "w-full border #{error_border(f.object, :purchase_quantity)} rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500" %>
      <%= render "shared/field_errors", object: material, field: :purchase_quantity %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :unit, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :unit, Material::ALLOWED_UNITS.map { |u| [u, u] },
          {}, class: "w-full border #{error_border(f.object, :unit)} rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500" %>
      <%= render "shared/field_errors", object: material, field: :unit %>
    </div>

    <div>
      <span class="block text-sm font-medium text-gray-700 mb-1">単価</span>
      <p class="px-3 py-2 text-sm text-gray-500" data-unit-price-target="unitPrice">
        <%= formatted_unit_price(material) %>
      </p>
    </div>
  </div>

  <div class="flex items-center">
    <%= f.check_box :additive, class: "rounded #{error_border(f.object, :additive)} text-orange-500 focus:ring-orange-500 cursor-pointer" %>
    <%= f.label :additive, class: "ml-2 text-sm text-gray-700 cursor-pointer" %>
    <%= render "shared/field_errors", object: material, field: :additive %>
  </div>

  <hr class="my-6 border-gray-200">

  <div>
    <span class="block text-sm font-medium text-gray-700 mb-3">栄養成分（100gあたり）</span>
    <p class="text-xs text-gray-500 mb-3">パッケージに記載の値を入力してください（任意）</p>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :energy, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :energy, step: 0.01, min: 0,
            class: "w-full border #{error_border(f.object, :energy)} rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500" %>
        <%= render "shared/field_errors", object: material, field: :energy %>
      </div>
      <div>
        <%= f.label :protein, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :protein, step: 0.01, min: 0,
            class: "w-full border #{error_border(f.object, :protein)} rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500" %>
        <%= render "shared/field_errors", object: material, field: :protein %>
      </div>
      <div>
        <%= f.label :fat, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :fat, step: 0.01, min: 0,
            class: "w-full border #{error_border(f.object, :fat)} rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500" %>
        <%= render "shared/field_errors", object: material, field: :fat %>
      </div>
      <div>
        <%= f.label :carbohydrate, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :carbohydrate, step: 0.01, min: 0,
            class: "w-full border #{error_border(f.object, :carbohydrate)} rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500" %>
        <%= render "shared/field_errors", object: material, field: :carbohydrate %>
      </div>
      <div>
        <%= f.label :salt, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :salt, step: 0.01, min: 0,
            class: "w-full border #{error_border(f.object, :salt)} rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500" %>
        <%= render "shared/field_errors", object: material, field: :salt %>
      </div>
    </div>
  </div>

  <hr class="my-6 border-gray-200">

  <div>
    <span class="block text-sm font-medium text-gray-700 mb-3">アレルゲン</span>

    <div class="mb-3">
      <p class="text-xs font-medium text-gray-500 mb-2">特定原材料（義務）</p>
      <div class="grid grid-cols-3 gap-2">
        <%= f.collection_check_boxes :allergen_ids, @required_allergens, :id, :name do |b| %>
          <%= b.label class: "inline-flex items-center text-sm cursor-pointer" do %>
            <%= b.check_box class: "rounded text-orange-500 focus:ring-orange-500 cursor-pointer" %>
            <span class="ml-1.5"><%= b.text %></span>
          <% end %>
        <% end %>
      </div>
    </div>

    <div>
      <p class="text-xs font-medium text-gray-500 mb-2">特定原材料に準ずるもの（推奨）</p>
      <div class="grid grid-cols-3 gap-2">
        <%= f.collection_check_boxes :allergen_ids, @recommended_allergens, :id, :name do |b| %>
          <%= b.label class: "inline-flex items-center text-sm cursor-pointer" do %>
            <%= b.check_box class: "rounded text-orange-500 focus:ring-orange-500 cursor-pointer" %>
            <span class="ml-1.5"><%= b.text %></span>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div>
    <%= f.submit class: "w-full bg-orange-500 text-white px-6 py-3 rounded-lg hover:bg-orange-600 text-sm font-medium cursor-pointer" %>
  </div>
<% end %>
