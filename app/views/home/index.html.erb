<% if user_signed_in? %>
  <div class="bg-white rounded-xl shadow-sm p-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">ようこそ</h1>
    <p class="text-gray-600"><%= current_user.name.presence || current_user.email %>さん</p>
  </div>
<% else %>
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <h1 class="text-4xl font-bold text-gray-900 mb-3">カシラク</h1>
    <p class="text-gray-600 mb-8">個人菓子店向けの原価計算アプリ</p>
    <div class="space-y-3">
      <%= button_to "Googleでログイン",
          user_google_oauth2_omniauth_authorize_path,
          method: :post,
          data: { turbo: false },
          class: "w-64 bg-orange-500 text-white px-6 py-3 rounded-lg hover:bg-orange-600 text-sm font-medium cursor-pointer" %>
      <%= button_to "ゲストログイン", guest_sign_in_path,
          class: "w-64 bg-white border border-orange-500 text-orange-500 px-6 py-3 rounded-lg hover:bg-orange-50 text-sm font-medium cursor-pointer" %>
    </div>
  </div>
<% end %>
